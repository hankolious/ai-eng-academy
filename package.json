    "ts-fsrs": "^4.6.0",
    "typescript": "^5.6.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "fake-indexeddb": "^6.0.0",
    "puppeteer": "^23.10.4",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
