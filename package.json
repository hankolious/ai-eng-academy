{
  "name": "pyodide-offline-spike",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.json && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "preview": "vite preview --port 4173 --strictPort",
    "measure": "node scripts/measure.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "pyodide": "0.26.4",
    "react": "^18.3.1",
